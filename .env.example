# Copy to .env on the VPS and fill in secrets there.
ENVIRONMENT=production
OPS_ROOT=/app
DATABASE_PATH=/app/tasks/queue.sqlite3
LOG_PATH=/app/logs/ops.jsonl

OPENAI_API_KEY=
OPENAI_CODEX_MODEL=gpt-5.3-codex
# Options: dry-run, codex-api, codex-cli
WORKER_BACKEND=dry-run
WORKER_POLL_SECONDS=15
WORKER_MAX_RETRIES=3
WORKER_REQUIRE_APPROVAL=false
CODEX_CLI_MODEL=gpt-5.3-codex
CODEX_CLI_SANDBOX=read-only
MEMORY_COMPRESSION_BACKEND=dry-run
MEMORY_CONTEXT_MAX_CHARS=12000

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

GITHUB_TOKEN=
GITHUB_OWNER=

# Optional bearer token for the Hermes OpenAI-compatible adapter.
HERMES_API_KEY=
